CLOUDFLARE_ACCOUNT_ID=<your-cloudflare-account-id>
D1_DATABASE_ID=<your-d1-database-id>
ALLOWED_EMAILS=<your-email@example.com>
ATTACHMENTS_KV_ID=<your-kv-namespace-id>
WORKER_URL=https://<your-worker-name>.<your-subdomain>.workers.dev
WORKER_VERSION_ID=<filled-after-deploy>

# Replace with your long-lived Cloudflare API token.
CLOUDFLARE_API_TOKEN=<create-a-new-api-token-in-cloudflare>

# Replace with your current worker secrets.
JWT_SECRET=<store-your-current-jwt-secret-here>
JWT_REFRESH_SECRET=<store-your-current-jwt-refresh-secret-here>

# Optional if you move attachments to R2 later.
R2_NAME=
